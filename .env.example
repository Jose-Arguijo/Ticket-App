PORT=4173
NODE_ENV=development

# Required in deployed environments. Local development falls back to data/db.json when this is blank.
MONGODB_URI=
MONGODB_DB=ticket_app
MONGODB_COLLECTION=app_state

# Only needed if your frontend and API are on different origins.
# Example: https://your-ticket-app.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=

# Keep Lax for same-origin Render or Vercel deployments.
# Use SameSite=None and COOKIE_SECURE=true only for cross-site frontend/API deployments.
COOKIE_SAMESITE=Lax
COOKIE_SECURE=false
